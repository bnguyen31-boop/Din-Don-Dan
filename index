  const laneMap = { left: 0, down: 1, up: 2, right: 3 };

let chartNotes = realChart.map(n => ({
    lane: laneMap[n.key],
    spawnTime: n.time - 2.2, // Neal.fun offset
    spawned: false
}));

function spawnFromChart(currentTime) {
  for (const n of chartNotes) {
    if (!n.spawned && currentTime >= n.spawnTime) {
      spawnNoteInLane(n.lane);
      n.spawned = true;
    }
  }
}
function spawnNoteInLane(laneIndex) {
  const arrow = arrows[laneIndex];
  const note = document.createElement("div");
  note.className = "note";
  note.textContent = arrow;

  const keyRect = arrowKeys[laneIndex].getBoundingClientRect();
  const gameRect = gameRoot.getBoundingClientRect();
  const localX = keyRect.left - gameRect.left;

  note.style.left = localX + "px";
  note.style.top = "-80px";

  gameRoot.appendChild(note);
  notes.push(note);
  totalNotes++;

  setTimeout(() => {
    if (notes.includes(note)) {
      notes = notes.filter(n => n !== note);
      missCount++;
      updateHUD();
    }
    note.remove();
  }, 3200);
}

let startTime = 0;

function gameLoop() {
  if (!running) return;

  const now = performance.now();
  const t = (now - startTime) / 1000;

  spawnFromChart(t);

  requestAnimationFrame(gameLoop);
}

  
const gameRoot = document.getElementById("gameRoot");
const bgVideo = document.getElementById("bgVideo");
const bubbles = document.querySelector(".bubbles");
const arrowKeys = document.querySelectorAll(".arrow-key");

const hitCountEl = document.getElementById("hitCount");
const missCountEl = document.getElementById("missCount");
const accuracyTextEl = document.getElementById("accuracyText");

const statsBox = document.getElementById("statsBox");
const statsHitEl = document.getElementById("statsHit");
const statsMissEl = document.getElementById("statsMiss");
const statsAccuracyEl = document.getElementById("statsAccuracy");
const restartBtn = document.getElementById("restartBtn");

const arrows = ["←","↓","↑","→"];
const keyMap = {
  ArrowLeft: "←",
  ArrowDown: "↓",
  ArrowUp: "↑",
  ArrowRight: "→"
};

let notes = [];
let running = true;
let hitCount = 0;
let missCount = 0;
let totalNotes = 0;

const tolerance = 60;  // forgiving timing
const targetYOffset = 0;
 

/* HUD UPDATE */
function updateHUD() {
  hitCountEl.textContent = hitCount;
  missCountEl.textContent = missCount;
  const acc = (hitCount + missCount) > 0 ? Math.round((hitCount / (hitCount + missCount)) * 100) : 100;
  accuracyTextEl.textContent = acc + "%";
}

/* SPARKLES */
function createSparkle(x, y) {
  for (let i = 0; i < 5; i++) {
    const s = document.createElement("div");
    s.className = "sparkle";

    const angle = (Math.PI * 2 * i) / 5;
    const offsetX = Math.cos(angle) * 10;
    const offsetY = Math.sin(angle) * 10;

    s.style.left = (x + offsetX) + "px";
    s.style.top = (y + offsetY) + "px";

    gameRoot.appendChild(s);
    setTimeout(() => s.remove(), 450);
  }
}

/* POP ANIMATION */
function popNote(note) {
  note.classList.add("note-pop");
  setTimeout(() => note.remove(), 220);
}

/* KEY FLASH */
function flashKey(arrowChar) {
  const index = arrows.indexOf(arrowChar);
  if (index === -1) return;
  const keyEl = arrowKeys[index];
  keyEl.classList.add("active");
  setTimeout(() => keyEl.classList.remove("active"), 120);
}

/* HIT DETECTION */
function handleHit(arrowChar) {
  const index = arrows.indexOf(arrowChar);
  const targetKey = arrowKeys[index];
  const targetRect = targetKey.getBoundingClientRect();
  const targetY = targetRect.top + targetRect.height / 2 + targetYOffset;

  let bestNote = null;
  let bestDist = Infinity;

  notes.forEach(note => {
    if (note.textContent.trim() !== arrowChar) return;
    const rect = note.getBoundingClientRect();
    const noteY = rect.top + rect.height / 2;
    const dist = Math.abs(noteY - targetY);
    if (dist < bestDist) {
      bestDist = dist;
      bestNote = note;
    }
  });

  if (bestNote && bestDist <= tolerance) {
    hitCount++;
    notes = notes.filter(n => n !== bestNote);

    const rect = bestNote.getBoundingClientRect();
    const gameRect = gameRoot.getBoundingClientRect();
    createSparkle(rect.left - gameRect.left + rect.width / 2,
                  rect.top - gameRect.top + rect.height / 2);

    popNote(bestNote);
  } else {
    missCount++;
  }

  updateHUD();
}

/* KEYBOARD INPUT */
document.addEventListener("keydown", e => {
  if (!running) return;
  const arrowChar = keyMap[e.key];
  if (!arrowChar) return;
  flashKey(arrowChar);
  handleHit(arrowChar);
});

function startGame() {
  keysPressed = {};
  running = true;
  hitCount = 0;
  missCount = 0;
  totalNotes = 0;
  updateHUD();
  statsBox.style.display = "none";

  notes.forEach(n => n.remove());
  notes = [];

  chartNotes.forEach(n => n.spawned = false);

  bgVideo.currentTime = 0;
  bgVideo.play();

  startTime = performance.now();
  gameLoop();

  stageTimer = setTimeout(endStage, 102000);
}

/* END GAME */
function endStage() {
  running = false;
  clearTimeout(stageTimer);

  setTimeout(() => {
    notes.forEach(n => n.remove());
    notes = [];
  }, 400);

  bgVideo.pause();

const acc = (hitCount + missCount) > 0 ? Math.round((hitCount / (hitCount + missCount)) * 100) : 0;
  statsHitEl.textContent = hitCount;
  statsMissEl.textContent = missCount;
  statsAccuracyEl.textContent = acc + "%";

  statsBox.style.display = "block";
}
/* RESTART */
restartBtn.addEventListener("click", startGame);

/* INIT */
startGame();
