<style>
/* RESET + FONT */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
}
html, body {
  width: 100%;
  height: 100%;
 background: linear-gradient(180deg, #ff7ad9, #b347ff); 
font-family: Roboto, sans-serif;
overflow: hidden;
  -webkit-font-smoothing: antialiased;
}
@font-face {
  font-family: Roboto;
  src: url("https://fonts.gstatic.com/s/roboto/v30/KFOmCnqEu92Fr1Mu4mxM.woff2");
}
body {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* OUTER CONTAINER */
.captcha-container {
  border: 0px;
  padding: 6px;
  max-width: 460px;
  margin-top: 30px;
  
}

/* GAME BOX — EXACT 466×466 */
.game {
  position: relative;
  width: 466px;
  height: 466px;
  overflow: hidden;
  border-radius: 10px;
  background: transparent;
  touch-action: manipulation;
  user-select: none;
}

/* BACKGROUND VIDEO */
.bg-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* fits inside 466x466 */
  z-index: 0;
  pointer-events: none;
}

/* OVERLAY GRADIENT */
.overlay-gradient {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top, rgba(255,255,255,0.25), transparent 55%),
    linear-gradient(180deg, rgba(0,0,0,0.1), rgba(0,0,0,0.85));
  z-index: 1;
  pointer-events: none;
}

/* BUBBLES */
.bubbles {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 2;
}
.bubble {
  position: absolute;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: radial-gradient(circle, #fff 0, #ffbdfc 40%, transparent 70%);
  opacity: 0.5;
  animation: floatUp 6s linear infinite;
}
@keyframes floatUp {
  from { transform: translateY(100%); opacity: 0; }
  20% { opacity: 0.7; }
  to { transform: translateY(-120%); opacity: 0; }
}

/* HUD */
.hud {
  position: absolute;
  top: 12px;
  left: 14px;
  right: 14px;
  display: flex;
  justify-content: space-between;
  color: #fff;
  font-size: 13px;
  text-shadow: 0 0 4px rgba(0,0,0,0.8);
  z-index: 3;
}
.hud .label { opacity: 0.8; }
.hud .value { font-weight: 700; }

/* BOTTOM ARROWS — EXACT SIZE 101.5×45 */
.arrows-container {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  width: 430px; /* ← original width for 4×101.5px arrows */
  display: flex;
  justify-content: space-between;
  z-index: 3;
}

.arrow-key {
  width: 101.5px;
  height: 45px;
  font-size: 20px;
  border-radius: 5px;
  background: rgba(145,56,145,.3);
  border: 1px solid #fff;
  color: #fff;
  font-weight: 700;
  text-shadow: 0 0 10px #913891;
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: 0.1s;
}
.arrow-key.active {
  background: rgba(200,90,200,.6);
  box-shadow:
    0 0 10px rgba(255,200,255,0.9),
    0 0 20px rgba(255,150,255,0.8);
  transform: scale(0.95);
}

/* FALLING NOTES — EXACT SAME SIZE */
.note {
  position: absolute;
  width: 101.5px;
  height: 45px;
  font-size: 20px;
  border-radius: 5px;
  

  /* transparent interior */
  background: rgba(255,255,255,0);

  /* glowing outline */
  border: 2px solid rgba(255,210,255,0.9);
  box-shadow:
    0 0 8px rgba(255,200,255,0.9),
    0 0 14px rgba(145,56,145,0.9);

  backdrop-filter: blur(3px);
  color: rgba(255,255,255,0.95);
  text-shadow: 0 0 10px #fff;

  display: flex;
  align-items: center;
  justify-content: center;

  animation: fallSlow 3.2s linear forwards;
  z-index: 3;
}
@keyframes fallSlow {
  from { top: -80px; }
  to { top: 110%; }
}

/* POP BIGGER */
.note-pop {
  animation: notePop 0.22s ease-out forwards;
}
@keyframes notePop {
  0%   { transform: scale(1);     opacity: 1; }
  40%  { transform: scale(1.25);  opacity: 1; }
  100% { transform: scale(1.55) translateY(-8px); opacity: 0; }
}

/* SPARKLES */
.sparkle {
  position: absolute;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: radial-gradient(circle, #fff 0%, #ffe6ff 40%, transparent 70%);
  mix-blend-mode: screen;
  animation: sparklePop 0.45s ease-out forwards;
  z-index: 4;
}
@keyframes sparklePop {
  0% { transform: scale(0.3); opacity: 1; }
  60% { transform: scale(1.4); opacity: 0.9; }
  100% { transform: scale(1.8) translateY(-6px); opacity: 0; }
}

/* STATS BOX */
.stats {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300px;
  padding: 20px 30px;
  border-radius: 10px;

  background: rgba(201,71,171,.6);
  border: 1px solid hsla(0,0%,100%,.65);
  box-shadow:
    0 0 5px hsla(0,0%,100%,.5),
    0 0 10px rgba(145,56,145,.8);

  backdrop-filter: blur(10px);
  color: #fff;
  z-index: 10;
  display: none;
}

/* BLUE-GLOW TEXT */
.stats-title,
.stats-item {
  color: #fff;
  font-weight: 700;
  text-shadow: 0 0 10px #2196da;
}
.stats-title {
  font-size: 20px;
  margin-bottom: 12px;
}
.stats-item {
  font-size: 17px;
  margin-bottom: 10px;
}

/* TRY AGAIN BUTTON */
.stats-btn {
  background: hsla(0,0%,100%,.2);
  border: 1px solid hsla(0,0%,100%,.65);
  border-radius: 5px;
  box-shadow:
    0 0 5px hsla(0,0%,100%,.5),
    0 0 10px rgba(145,56,145,.8);
  color: #fff;
  cursor: pointer;
  font-size: 17px;
  font-weight: 700;
  margin-top: 20px;
  padding: 10px 20px;
  width: 100%;
}
</style>
